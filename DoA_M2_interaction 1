
<div id="rise-process-vertical" class="rise-process">
    <div class="process-wrap">
        <svg class="process-svg"></svg>
        <div class="process-column"></div>
    </div>
</div>

<style>

#rise-process-vertical{
    font-family:"Montserrat",Arial,sans-serif;
    font-size:18px;
    max-width:820px;
    margin:auto;
    color:#000;
}

.process-wrap{position:relative;padding:10px;}

.process-column{
display:flex;
flex-direction:column;
gap:40px;
position:relative;
z-index:2;
}

.process-step{
border-radius:14px;
padding:22px 24px;
cursor:pointer;
box-shadow:0 4px 10px rgba(0,0,0,.08),0 1px 2px rgba(0,0,0,.06);
transition:.35s;
opacity:0;
transform:translateY(25px)
}

.process-step.visible{
opacity:1;
transform:translateY(0);
}

.process-step:nth-child(1){background:#F1860C;}
.process-step:nth-child(2){background:#F49A2E;}
.process-step:nth-child(3){background:#F7B55D;}
.process-step:nth-child(4){background:#FAD08E;}

.process-step.open{
background:#d36f00;
color:#fff;
}

.step-title{font-weight:700;margin-bottom:6px}
.toggle-label{font-weight:500}

.opened-label{
display:none;
font-weight:700;
font-size:14px;
margin-bottom:8px;
}

.process-step.open .opened-label{display:block;}

.step-details{
display:none;
line-height:1.5;
margin-top:8px;
white-space:pre-line;
}

.process-step.open .step-details{display:block;}

.process-svg{
position:absolute;
inset:0;
width:100%;
height:100%;
pointer-events:none;
}

.connector{
stroke:#00588B;
stroke-width:3;
stroke-dasharray:8 6;
fill:none;
}

</style>

<script>

window.addEventListener("load",function(){

setTimeout(function(){

const steps=[

{
title:"HoldCo Reserved Matters",
text:`
Examples are:

• Company budget and amendments
• Any excluded project spend
• Approval of all Project Agreements and amendments over £35m
• Material Contracts over £100m
• Amendments to Material Contracts over £25m
• Property transactions
• Disposals
• Loans and guarantees
• JVS
• Strategic Spares
• Certain appointments and remuneration`
},

{
title:"GenCo Reserved Matters",
text:`
Examples are:

• Company budget – including review and policy
• Business policies
• Material Contracts over £50m
• Amendments to Material Contracts over £25m pa
• Litigation over £10m
• Amendments to DCO
• Employee remuneration strategy`
},

{
title:"Protected Shareholders Reserved Matters",
text:`
Examples are:

• Changes to acceptable credit rating in Investment Agreement
• Material variation to scope
• Any action that would result in permanent shutdown
• Dividends not per payments policy
• Changes to constitutional documents`
},

{
title:"Shareholders Reserved Matters",
text:`

Examples are:

• Appointment of Chair
• Joint ventures
• Special severance payments
• Tax policy
• Additional equity requirements`
}

];

const root=document.getElementById("rise-process-vertical");
if(!root) return;

const column=root.querySelector(".process-column");
const svg=root.querySelector(".process-svg");

steps.forEach(function(s){

const step=document.createElement("div");
step.className="process-step";

step.innerHTML=
'<div class="opened-label">Opened</div>'+
'<div class="step-title">'+s.title+' — <span class="toggle-label">Select to open</span></div>'+
'<div class="step-details">'+s.text+'</div>';

column.appendChild(step);

step.addEventListener("click",function(){

const all=root.querySelectorAll(".process-step");

all.forEach(function(a){
a.classList.remove("open");
a.querySelector(".toggle-label").textContent="Select to open";
});

if(!step.classList.contains("open")){
step.classList.add("open");
step.querySelector(".toggle-label").textContent="Select to close";
}

setTimeout(draw,200);

});

});

const boxes=root.querySelectorAll(".process-step");

boxes.forEach(function(b,i){
setTimeout(function(){
b.classList.add("visible");
draw();
},300*i);
});

function draw(){

svg.innerHTML="";

const wrap=root.querySelector(".process-wrap").getBoundingClientRect();
svg.setAttribute("viewBox","0 0 "+wrap.width+" "+wrap.height);

const items=column.children;

for(let i=0;i<items.length-1;i++){

const a=items[i].getBoundingClientRect();
const b=items[i+1].getBoundingClientRect();

let line=document.createElementNS("http://www.w3.org/2000/svg","line");

line.setAttribute("x1",a.left+a.width/2-wrap.left);
line.setAttribute("x2",a.left+a.width/2-wrap.left);
line.setAttribute("y1",a.bottom-wrap.top);
line.setAttribute("y2",b.top-wrap.top);
line.setAttribute("class","connector");

svg.appendChild(line);
}
}

window.addEventListener("resize",function(){
setTimeout(draw,400);
});

setTimeout(function(){
window.parent.postMessage({type:'MIGHTY_INTERACTIVE_COMPLETE'},'*');
},1500); // ← THIS must fire LAST

},500);

});

</script>
